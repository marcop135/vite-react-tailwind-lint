{
  "name": "vite-react-tailwind-lint",
  "private": true,
  "version": "1.7.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" && stylelint \"src/**/*.css\" && htmlhint index.html",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix && stylelint \"src/**/*.css\" --fix && htmlhint index.html",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,css,scss,html,md}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,ts,tsx,css,scss,html,md}'",
    "clean": "rm -rf dist coverage",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "release:check": "npm run lint && npm run format:check && npm run test:ci && npm run build && npm audit --audit-level=moderate",
    "analyze": "vite build --mode analyze",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.11.0",
    "htmlhint": "^1.8.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.7",
    "rollup-plugin-visualizer": "^6.0.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4.3.1",
    "vite": "^7.3.5",
    "vite-plugin-eslint2": "^5.3.0",
    "vite-plugin-stylelint": "^6.3.0",
    "vitest": "^4.1.9"
  }
}
